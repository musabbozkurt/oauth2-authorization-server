<?xml version="1.0" encoding="UTF-8"?>
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0">

    <!--
        Global: ignore pre-release versions (case-insensitive).
        This prevents stable dependencies from being upgraded to pre-release versions.
        Dependencies that intentionally use pre-release qualifiers must be excluded via the per-artifact rules below.
    -->
    <ignoreVersions>
        <ignoreVersion type="regex">(?i).*[-.]alpha[-.]?\d*</ignoreVersion>
        <ignoreVersion type="regex">(?i).*[-.]beta[-.]?\d*</ignoreVersion>
        <ignoreVersion type="regex">(?i).*[-.]rc[-.]?\d*</ignoreVersion>
        <ignoreVersion type="regex">(?i).*[-.]cr[-.]?\d*</ignoreVersion>
        <ignoreVersion type="regex">(?i).*[-.]m\d+</ignoreVersion>
        <ignoreVersion type="regex">(?i).*-snapshot</ignoreVersion>
        <ignoreVersion type="regex">(?i).*[-.]milestone[-.]?\d*</ignoreVersion>
    </ignoreVersions>

    <rules>
        <!--
            OpenTelemetry instrumentation: uses -alpha as a standard release qualifier (e.g., 2.27.0-alpha).
            Allow alpha-to-alpha upgrades while still blocking snapshot/beta/RC/milestone.
        -->
        <rule groupId="io.opentelemetry.instrumentation">
            <ignoreVersions>
                <ignoreVersion type="regex">(?i).*[-.]beta[-.]?\d*</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]rc[-.]?\d*</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]cr[-.]?\d*</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]m\d+</ignoreVersion>
                <ignoreVersion type="regex">(?i).*-snapshot</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]milestone[-.]?\d*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!--
            Instancio: uses -RC as a standard release qualifier (e.g., 6.0.0-RC1).
            Allow RC-to-RC upgrades while still blocking snapshot/milestone.
        -->
        <rule groupId="org.instancio">
            <ignoreVersions>
                <ignoreVersion type="regex">(?i).*[-.]m\d+</ignoreVersion>
                <ignoreVersion type="regex">(?i).*-snapshot</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]milestone[-.]?\d*</ignoreVersion>
            </ignoreVersions>
        </rule>

        <!--
            MapStruct: uses Beta as a standard release qualifier (e.g., 1.7.0.Beta1).
            Allow beta-to-beta upgrades while still blocking snapshot/milestone.
        -->
        <rule groupId="org.mapstruct">
            <ignoreVersions>
                <ignoreVersion type="regex">(?i).*[-.]m\d+</ignoreVersion>
                <ignoreVersion type="regex">(?i).*-snapshot</ignoreVersion>
                <ignoreVersion type="regex">(?i).*[-.]milestone[-.]?\d*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
</ruleset>
